{
  "schemaVersion": 1,
  "id": "bitwardenapi",
  "version": "${version}",
  "name": "Bitwarden API",
  "description": "",
  "authors": ["JGJ52"],
  "contact": {"Discord Server": "https://discord.gg/5pjP2DxQK8"},
  "license": "GPL-3.0",
  "icon": "assets/bitwardenapi/icon.png",
